# Server
NODE_ENV=development
PORT=4000
# Comma-separated list of origins allowed to call this API
CORS_ORIGIN=http://localhost:8934,http://localhost:3000

# PostgreSQL
DATABASE_URL=postgres://brandco:brandco@localhost:5432/brandco
# Set to true if your DB provider requires SSL (e.g. most hosted providers)
DATABASE_SSL=false

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=brandco_token

# Paystack — get these from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Where Paystack should redirect the shopper after payment
PAYSTACK_CALLBACK_URL=http://localhost:8934/marketplace.html?payment=callback

# Delivery
FREE_DELIVERY_THRESHOLD=100000
DELIVERY_FEE=2500
